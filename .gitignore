# Git ignore for the entire tourism-website project
# Covers backend (Node), frontend (Vite), common editor/OS files, caches, and build outputs.

#### Node / package managers
# Node modules (backend & frontend)
node_modules/
**/node_modules/

# npm / yarn / pnpm debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

#### Build outputs
# Vite/Front-end build
dist/
public/build/
.vite/

# Generic build outputs
build/
.out/
coverage/
.nyc_output/

#### Caches
.cache/
.parcel-cache/
.cache-loader
.cache-vite
/.turbo/

#### Environment files (do NOT ignore example files)
.env
.env.local
.env.*.local
.env.test
.env.production

#### Logs and runtime files
logs/
*.log
*.log.*
pids/
*.pid
*.seed
*.pid.lock

#### OS generated files
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
Icon?
$RECYCLE.BIN/

#### Editors / IDEs
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.iml
*.swp
*.swo

#### TypeScript
*.tsbuildinfo

#### Storybook / other dev tools
.cache-storybook
.storybook/

#### Testing
coverage/
coverage-final.json

#### Misc
*.local
*.cache
/.parcel-cache/
/.next/

# Keep lockfiles (package-lock.json / yarn.lock / pnpm-lock.yaml) tracked
# Keep README, examples, and other documentation files tracked

#### Per-package (frontend & backend) - explicit rules
# Frontend
/frontend/node_modules/
/frontend/**/node_modules/
/frontend/dist/
/frontend/.vite/
/frontend/build/
/frontend/.env
/frontend/.env.local
/frontend/npm-debug.log*
/frontend/yarn-debug.log*

# Backend
/backend/node_modules/
/backend/**/node_modules/
/backend/dist/
/backend/build/
/backend/coverage/
/backend/.env
/backend/.env.local
/backend/npm-debug.log*
/backend/yarn-debug.log*

